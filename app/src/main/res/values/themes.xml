<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.BanQuanAo" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/bg_app</item>
        <item name="colorSurface">@color/bg_app</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Theme.BanQuanAo" parent="Base.Theme.BanQuanAo" />

    <!-- Theme cho Login/Register: status bar tối, icon trắng -->
    <style name="Theme.BanQuanAo.Auth" parent="Theme.BanQuanAo">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/login_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <!-- Bottom navigation styling -->
    <style name="Widget.App.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/bn_item_color</item>
        <item name="itemTextColor">@color/bn_item_color</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.App.BottomNavigation.ActiveIndicator</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemTextAppearanceActive">@style/TextAppearance.App.BottomNavLabel.Active</item>
        <item name="itemTextAppearanceInactive">@style/TextAppearance.App.BottomNavLabel</item>
    </style>

    <style name="Widget.App.BottomNavigation.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@android:color/transparent</item>
    </style>

    <style name="TextAppearance.App.BottomNavLabel" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">11sp</item>
    </style>

    <style name="TextAppearance.App.BottomNavLabel.Active">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">11sp</item>
    </style>

    <!-- Section title -->
    <style name="TextAppearance.App.SectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

</resources>
