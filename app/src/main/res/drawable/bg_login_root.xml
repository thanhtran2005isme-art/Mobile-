<?xml version="1.0" encoding="utf-8"?>
<!-- Nền tối + vầng sáng tím phía trên dạng radial -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/login_bg" />
        </shape>
    </item>
    <item android:gravity="top">
        <shape android:shape="oval">
            <size android:width="500dp" android:height="600dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="300"
                android:centerX="0.5"
                android:centerY="0.4"
                android:startColor="#553B0764"
                android:endColor="#000B0B12" />
        </shape>
    </item>
</layer-list>
