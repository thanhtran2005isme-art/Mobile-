<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_section"
    android:fillViewport="true"
    android:overScrollMode="never"
    tools:context=".ui.profile.ProfileFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ========== HEADER CAM ========== -->
        <LinearLayout
            android:id="@+id/headerRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_profile_header"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingTop="@dimen/space_md"
            android:paddingBottom="@dimen/space_xl">

            <!-- Action row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btnTheme"
                    android:layout_width="@dimen/profile_action_icon_size"
                    android:layout_height="@dimen/profile_action_icon_size"
                    android:layout_marginEnd="@dimen/space_lg"
                    android:src="@drawable/ic_sun" />

                <ImageView
                    android:id="@+id/btnCart"
                    android:layout_width="@dimen/profile_action_icon_size"
                    android:layout_height="@dimen/profile_action_icon_size"
                    android:layout_marginEnd="@dimen/space_lg"
                    android:src="@drawable/ic_cart"
                    android:tint="@color/white" />

                <ImageView
                    android:id="@+id/btnSupport"
                    android:layout_width="@dimen/profile_action_icon_size"
                    android:layout_height="@dimen/profile_action_icon_size"
                    android:src="@drawable/ic_headset"
                    android:tint="@color/white" />
            </LinearLayout>

            <!-- Profile row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="@dimen/profile_avatar_size"
                    android:layout_height="@dimen/profile_avatar_size"
                    android:background="@drawable/bg_profile_avatar">

                    <ImageView
                        android:id="@+id/profileAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="6dp"
                        android:src="@drawable/ic_avatar_placeholder" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_md"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/profileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_name"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_headline"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/profileMeta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/profile_phone_role"
                        android:textColor="#E6FFFFFF"
                        android:textSize="@dimen/text_body" />
                </LinearLayout>
            </LinearLayout>

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnEditProfile"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_white_filled"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/profile_edit"
                    android:textColor="@color/profile_orange"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnLogout"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="@dimen/space_md"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_white_outline"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/profile_logout"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- ========== ĐƠN MUA ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_md"
            android:layout_marginTop="@dimen/space_md"
            android:background="@drawable/bg_card_section"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingVertical="@dimen/space_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/profile_orders"
                    android:textAppearance="@style/TextAppearance.App.SectionTitle" />

                <TextView
                    android:id="@+id/orderHistory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_small"
                    tools:text="Xem lịch sử mua hàng (2)" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:orientation="horizontal">

                <include
                    android:id="@+id/orderPending"
                    layout="@layout/item_profile_quick_action" />

                <include
                    android:id="@+id/orderPickup"
                    layout="@layout/item_profile_quick_action" />

                <include
                    android:id="@+id/orderDelivery"
                    layout="@layout/item_profile_quick_action" />

                <include
                    android:id="@+id/orderReview"
                    layout="@layout/item_profile_quick_action" />
            </LinearLayout>
        </LinearLayout>

        <!-- ========== TIỆN ÍCH ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_md"
            android:layout_marginTop="@dimen/space_md"
            android:background="@drawable/bg_card_section"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingVertical="@dimen/space_lg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_utilities"
                android:textAppearance="@style/TextAppearance.App.SectionTitle" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:orientation="horizontal">

                <include
                    android:id="@+id/utilVoucher"
                    layout="@layout/item_profile_quick_action" />

                <include
                    android:id="@+id/utilPoints"
                    layout="@layout/item_profile_quick_action" />

                <include
                    android:id="@+id/utilWallet"
                    layout="@layout/item_profile_quick_action" />
            </LinearLayout>
        </LinearLayout>

        <!-- ========== DỊCH VỤ THỜI TRANG ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_md"
            android:layout_marginTop="@dimen/space_md"
            android:background="@drawable/bg_card_section"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingVertical="@dimen/space_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/profile_services"
                    android:textAppearance="@style/TextAppearance.App.SectionTitle" />

                <TextView
                    android:id="@+id/servicesViewMore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_view_more"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_small" />
            </LinearLayout>

            <!-- Card to "Yêu thích" -->
            <LinearLayout
                android:id="@+id/cardFavorite"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:background="@drawable/bg_card_subitem"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="@dimen/space_lg">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_heart_orange" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:text="@string/profile_favorite"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 2 card nhỏ song song -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/cardAddress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_subitem"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/space_lg">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_address" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:text="@string/profile_address"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_md"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_subitem"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/space_lg">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_trending" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:text="@string/profile_style"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ========== QUẢN TRỊ ========== -->
        <LinearLayout
            android:id="@+id/sectionAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_md"
            android:layout_marginTop="@dimen/space_md"
            android:background="@drawable/bg_card_section"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingVertical="@dimen/space_lg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_admin"
                android:textAppearance="@style/TextAppearance.App.SectionTitle" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:text="@string/profile_admin_desc"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body" />

            <LinearLayout
                android:id="@+id/cardAdminPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:background="@drawable/bg_card_subitem"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/space_md"
                android:paddingVertical="@dimen/space_md">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_admin_sun" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_md"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_admin_panel"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_subtitle"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/profile_admin_panel_desc"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_small" />
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>
        </LinearLayout>

        <!-- ========== HỖ TRỢ ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_md"
            android:layout_marginTop="@dimen/space_md"
            android:layout_marginBottom="@dimen/space_3xl"
            android:background="@drawable/bg_card_section"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingVertical="@dimen/space_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:layout_marginBottom="@dimen/space_sm"
                android:text="@string/profile_support"
                android:textAppearance="@style/TextAppearance.App.SectionTitle" />

            <include
                android:id="@+id/supportHelp"
                layout="@layout/item_profile_support_row" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="36dp"
                android:background="@color/divider" />

            <include
                android:id="@+id/supportNotification"
                layout="@layout/item_profile_support_row" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="36dp"
                android:background="@color/divider" />

            <include
                android:id="@+id/supportCare"
                layout="@layout/item_profile_support_row" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="36dp"
                android:background="@color/divider" />

            <include
                android:id="@+id/supportPolicy"
                layout="@layout/item_profile_support_row" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
