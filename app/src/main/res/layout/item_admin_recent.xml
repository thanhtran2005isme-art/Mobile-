<?xml version="1.0" encoding="utf-8"?>
<!-- Một dòng "Hoạt động gần đây": chấm cam + tiêu đề đậm + meta xám -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="@dimen/space_md">

    <View
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="@dimen/space_md"
        android:background="@drawable/bg_recent_dot" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/recentTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_body"
            android:textStyle="bold"
            tools:text="Đơn KK260429105918 đang chờ xác nhận" />

        <TextView
            android:id="@+id/recentMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_muted"
            android:textSize="@dimen/text_small"
            tools:text="thanh • 29/04/2026 10:59 • 100.016.500đ" />
    </LinearLayout>
</LinearLayout>
