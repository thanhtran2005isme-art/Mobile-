<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/addCategoryRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_section"
    tools:context=".ui.admin.category.AddCategoryActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/space_md"
            android:paddingVertical="@dimen/space_sm">

            <FrameLayout
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/ripple_circle"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_back"
                    android:tint="@color/text_primary" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_sm"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/screenTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/add_category_title"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/add_category_subtitle"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_small" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="80dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_md"
            android:paddingTop="@dimen/space_md">

            <!-- Tên -->
            <include android:id="@+id/fieldName" layout="@layout/layout_add_product_field" />
            <include android:id="@+id/fieldSlug" layout="@layout/layout_add_product_field" />

            <!-- Cấp danh mục -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:text="@string/add_category_level"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/levelChip1"
                    style="@style/Widget.App.AdminFilterChip"
                    android:text="C1" />

                <TextView
                    android:id="@+id/levelChip2"
                    style="@style/Widget.App.AdminFilterChip"
                    android:layout_marginStart="@dimen/space_sm"
                    android:text="C2" />

                <TextView
                    android:id="@+id/levelChip3"
                    style="@style/Widget.App.AdminFilterChip"
                    android:layout_marginStart="@dimen/space_sm"
                    android:text="C3" />
            </LinearLayout>

            <!-- Cha (chỉ hiện khi level >= 2) -->
            <LinearLayout
                android:id="@+id/parentSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/add_category_parent"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/parentSelector"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/admin_field_height"
                    android:layout_marginTop="@dimen/space_sm"
                    android:background="@drawable/bg_admin_field"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/space_lg"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body"
                    tools:text="Phụ nữ" />
            </LinearLayout>

            <!-- Thứ tự -->
            <include android:id="@+id/fieldOrder" layout="@layout/layout_add_product_field" />

            <!-- Visibility -->
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchVisible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:checked="true"
                android:text="@string/add_category_visibility"
                android:textColor="@color/text_primary" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/white"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:padding="@dimen/space_md">

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_admin_btn_outline"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/add_product_cancel"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_body"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="@dimen/space_md"
            android:layout_weight="1"
            android:background="@drawable/bg_admin_btn_primary"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/add_category_save"
            android:textColor="@color/white"
            android:textSize="@dimen/text_body"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
