<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/registerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_root"
    android:fillViewport="true"
    android:overScrollMode="never"
    tools:context=".ui.auth.RegisterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/space_2xl"
        android:paddingTop="@dimen/space_lg"
        android:paddingBottom="@dimen/space_2xl">

        <!-- Back -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="@dimen/space_md"
            android:padding="4dp"
            android:src="@drawable/ic_back" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/space_3xl"
            android:gravity="center"
            android:text="@string/register_title_1"
            android:textColor="@color/login_text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:text="@string/register_title_2"
            android:textColor="@color/login_text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/space_md"
            android:gravity="center"
            android:text="@string/register_subtitle"
            android:textColor="@color/login_text_secondary"
            android:textSize="@dimen/text_body" />

        <!-- Inputs -->
        <EditText
            android:id="@+id/inputName"
            android:layout_width="match_parent"
            android:layout_height="@dimen/login_input_height"
            android:layout_marginTop="@dimen/space_2xl"
            android:autofillHints="name"
            android:background="@drawable/bg_login_input"
            android:hint="@string/register_name_hint"
            android:inputType="textPersonName"
            android:paddingHorizontal="@dimen/space_lg"
            android:textColor="@color/login_text_primary"
            android:textColorHint="@color/login_text_muted"
            android:textCursorDrawable="@null"
            android:textSize="@dimen/text_body" />

        <EditText
            android:id="@+id/inputPhone"
            android:layout_width="match_parent"
            android:layout_height="@dimen/login_input_height"
            android:layout_marginTop="@dimen/space_md"
            android:autofillHints="phone"
            android:background="@drawable/bg_login_input"
            android:hint="@string/register_phone_hint"
            android:inputType="phone"
            android:paddingHorizontal="@dimen/space_lg"
            android:textColor="@color/login_text_primary"
            android:textColorHint="@color/login_text_muted"
            android:textCursorDrawable="@null"
            android:textSize="@dimen/text_body" />

        <!-- Password with eye toggle -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/login_input_height"
            android:layout_marginTop="@dimen/space_md"
            android:background="@drawable/bg_login_input">

            <EditText
                android:id="@+id/inputPassword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:autofillHints="password"
                android:background="@android:color/transparent"
                android:hint="@string/register_password_hint"
                android:inputType="textPassword"
                android:paddingStart="@dimen/space_lg"
                android:paddingEnd="48dp"
                android:textColor="@color/login_text_primary"
                android:textColorHint="@color/login_text_muted"
                android:textCursorDrawable="@null"
                android:textSize="@dimen/text_body" />

            <ImageView
                android:id="@+id/btnTogglePassword"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="end|center_vertical"
                android:padding="11dp"
                android:src="@drawable/ic_eye_off" />
        </FrameLayout>

        <!-- Submit -->
        <TextView
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent"
            android:layout_height="@dimen/login_btn_height"
            android:layout_marginTop="@dimen/space_xl"
            android:background="@drawable/bg_login_btn_gradient"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:letterSpacing="0.05"
            android:text="@string/register_submit"
            android:textColor="@color/white"
            android:textSize="@dimen/text_body"
            android:textStyle="bold" />

        <!-- Divider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/login_input_stroke" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/space_md"
                android:text="@string/register_or_quick"
                android:textColor="@color/login_text_secondary"
                android:textSize="@dimen/text_small" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/login_input_stroke" />
        </LinearLayout>

        <!-- Social row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:gravity="center"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/socialApple"
                android:layout_width="@dimen/login_social_size"
                android:layout_height="@dimen/login_social_size"
                android:background="@drawable/bg_social_circle">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_apple" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/socialGoogle"
                android:layout_width="@dimen/login_social_size"
                android:layout_height="@dimen/login_social_size"
                android:layout_marginHorizontal="@dimen/space_lg"
                android:background="@drawable/bg_social_circle">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_google" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/socialTiktok"
                android:layout_width="@dimen/login_social_size"
                android:layout_height="@dimen/login_social_size"
                android:background="@drawable/bg_social_circle">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_tiktok" />
            </FrameLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/linkLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/space_2xl"
            android:gravity="center"
            android:text="@string/register_have_account"
            android:textColor="@color/login_text_secondary"
            android:textSize="@dimen/text_body" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
