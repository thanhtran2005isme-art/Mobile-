<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/space_md"
    android:background="@drawable/bg_admin_card"
    android:orientation="vertical"
    android:padding="@dimen/space_md">

    <!-- Top: thumb + info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="@dimen/admin_product_thumb"
            android:layout_height="@dimen/admin_product_thumb"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/productThumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                tools:src="@drawable/bg_product_1" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_md"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Status row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/productStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_admin_status_green"
                    android:paddingHorizontal="@dimen/space_sm"
                    android:paddingVertical="2dp"
                    android:textColor="@color/admin_status_green"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold"
                    tools:text="Đang bán" />

                <TextView
                    android:id="@+id/productVisibility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_sm"
                    android:background="@drawable/bg_admin_status_green"
                    android:paddingHorizontal="@dimen/space_sm"
                    android:paddingVertical="2dp"
                    android:textColor="@color/admin_status_green"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold"
                    tools:text="Đang hiển thị" />
            </LinearLayout>

            <TextView
                android:id="@+id/productName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_subtitle"
                android:textStyle="bold"
                tools:text="áo sơ mi" />

            <TextView
                android:id="@+id/productCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_small"
                tools:text="Danh mục: Đầm ôm" />

            <TextView
                android:id="@+id/productCollection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_small"
                tools:text="Bộ sưu tập: 6" />

            <TextView
                android:id="@+id/productSku"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_small"
                tools:text="Mã SP: KID-Đ-0002" />
        </LinearLayout>
    </LinearLayout>

    <!-- Price + stock -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/productPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/profile_orange"
            android:textSize="@dimen/text_subtitle"
            android:textStyle="bold"
            tools:text="100000000đ" />

        <TextView
            android:id="@+id/productStock"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_body"
            tools:text="Tồn kho 12" />
    </LinearLayout>

    <!-- Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/actionEdit"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_admin_btn_outline"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/admin_product_action_edit"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_body"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/actionToggle"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="@dimen/space_sm"
            android:layout_weight="1"
            android:background="@drawable/bg_admin_btn_outline"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_body"
            android:textStyle="bold"
            tools:text="Ẩn" />

        <TextView
            android:id="@+id/actionDelete"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="@dimen/space_sm"
            android:layout_weight="1"
            android:background="@drawable/bg_admin_btn_danger"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/admin_product_action_delete"
            android:textColor="@color/admin_status_red"
            android:textSize="@dimen/text_body"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
