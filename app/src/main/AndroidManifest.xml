<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BanQuanAo">

        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="true"
            android:configChanges="uiMode|orientation|screenSize"
            android:theme="@style/Theme.BanQuanAo.Auth">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false"
            android:configChanges="uiMode|orientation|screenSize"
            android:theme="@style/Theme.BanQuanAo.Auth"
            android:parentActivityName=".ui.auth.LoginActivity" />

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:configChanges="uiMode|orientation|screenSize"
            android:theme="@style/Theme.BanQuanAo" />

        <activity
            android:name=".ui.admin.AdminActivity"
            android:exported="false"
            android:configChanges="uiMode|orientation|screenSize"
            android:theme="@style/Theme.BanQuanAo"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ui.admin.product.AdminProductListActivity"
            android:exported="false"
            android:configChanges="uiMode|orientation|screenSize"
            android:theme="@style/Theme.BanQuanAo"
            android:parentActivityName=".ui.admin.AdminActivity" />

        <activity
            android:name=".ui.admin.product.AddProductActivity"
            android:exported="false"
            android:configChanges="uiMode|orientation|screenSize"
            android:theme="@style/Theme.BanQuanAo"
            android:parentActivityName=".ui.admin.product.AdminProductListActivity" />

        <activity
            android:name=".ui.admin.category.AdminCategoryListActivity"
            android:exported="false"
            android:configChanges="uiMode|orientation|screenSize"
            android:theme="@style/Theme.BanQuanAo"
            android:parentActivityName=".ui.admin.AdminActivity" />

        <activity
            android:name=".ui.admin.category.AddCategoryActivity"
            android:exported="false"
            android:configChanges="uiMode|orientation|screenSize"
            android:theme="@style/Theme.BanQuanAo"
            android:parentActivityName=".ui.admin.category.AdminCategoryListActivity" />

        <activity
            android:name=".ui.admin.order.AdminOrderListActivity"
            android:exported="false"
            android:configChanges="uiMode|orientation|screenSize"
            android:theme="@style/Theme.BanQuanAo"
            android:parentActivityName=".ui.admin.AdminActivity" />

    </application>

</manifest>
